  <style>
    :root{
      --wine:#82161F;
      --terra:#A8420E;
      --soft:#BD6F4C;
      --sand:#EECBaa;

      --bg: var(--sand);
      --ink: #120C0F;        /* MAIS ESCURO: leitura */
      --paper: #fff8f0;
      --line: rgba(130,22,31,.16);

      --radius: 18px;
      --shadow: 0 14px 40px rgba(20,10,12,.14);

      --serif: "Cormorant Garamond", serif;
      --text: "Lora", serif;
    }

    *{box-sizing:border-box}
    body{
      margin:0;
      font-family: var(--text);
      color: var(--ink);
      background: var(--bg);
      line-height:1.78;
      font-size:18.5px;       /* MAIOR: leitura desktop */
      font-weight:600;        /* SEMI-NEGRITO */
      text-rendering: geometricPrecision;
      -webkit-font-smoothing: antialiased;
    }

    a{color:inherit; text-decoration:none}
    .wrap{max-width:1120px; margin:0 auto; padding:0 20px}

    p, li{
      color: rgba(18,12,15,.90);
    }

    .pill{
      display:inline-flex; align-items:center; gap:10px;
      padding:10px 14px;
      border:1px solid var(--line);
      border-radius:999px;
      background:rgba(255,255,255,.35);
      backdrop-filter: blur(6px);
      font-size:15.5px;
      letter-spacing:.02em;
      color: rgba(18,12,15,.88);
      font-weight:600;
    }

    .star{
      width:10px; height:10px; display:inline-block;
      background: conic-gradient(from 0deg, var(--soft), var(--soft));
      clip-path: polygon(50% 0%, 61% 36%, 100% 50%, 61% 64%, 50% 100%, 39% 64%, 0% 50%, 39% 36%);
      opacity:.9;
    }

    header{
      position:sticky; top:0; z-index:20;
      background:rgba(238,203,170,.84);
      backdrop-filter: blur(10px);
      border-bottom:1px solid var(--line);
    }

    .nav{
      display:flex; align-items:center; justify-content:space-between;
      padding:12px 0;
      gap:18px;
    }

    .brand{
      display:flex; align-items:center; gap:12px;
      font-family: var(--serif);
      font-weight:700;
      letter-spacing:.20em;
      text-transform:uppercase;
      color: var(--wine);
    }

    .brand img{
      width:40px; height:40px; object-fit:contain;
      border-radius:999px;
      border:1px solid rgba(130,22,31,.14);
      background: rgba(255,255,255,.35);
      padding:6px;
    }

    nav ul{
      list-style:none; padding:0; margin:0;
      display:flex; gap:16px; align-items:center;
      font-size:15.5px;
      font-weight:600;
      color: rgba(18,12,15,.88);
    }

    nav a{
      padding:10px 10px;
      border-radius:12px;
    }
    nav a:hover{background:rgba(255,255,255,.35)}

    .cta{display:flex; gap:10px; align-items:center;}

    .btn{
      display:inline-flex; align-items:center; justify-content:center;
      padding:12px 14px;
      border-radius:14px;
      border:1px solid var(--line);
      background:rgba(255,255,255,.45);
      font-size:15.5px;
      font-weight:600;
      transition:.18s ease;
      white-space:nowrap;
      color: rgba(18,12,15,.92);
    }
    .btn:hover{transform:translateY(-1px)}
    .btn.primary{
      background: var(--wine);
      color: var(--paper);
      border-color: rgba(255,255,255,.12);
      box-shadow: 0 12px 28px rgba(130,22,31,.25);
    }
    .btn.ghost{background:transparent;}

    /* Hero */
