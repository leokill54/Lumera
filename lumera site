      font-weight:700;
      font-size:52px;
      line-height:1.05;
      margin:14px 0 12px;
      color:#1b0f12;
      letter-spacing:-.02em;
    }

    .lead{font-size:19px; max-width:62ch; font-weight:600;}

    .hero-actions{display:flex; gap:12px; flex-wrap:wrap; margin-top:10px;}

    .note{
      margin-top:14px;
      padding:12px 14px;
      border-radius:14px;
      border:1px solid rgba(130,22,31,.12);
      background: rgba(255,255,255,.35);
      font-size:15.5px;
      color: rgba(18,12,15,.90);
      font-weight:600;
    }

    .visual{
      background: rgba(255,255,255,.46);
      border:1px solid var(--line);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow:hidden;
      position:relative;
      padding:18px;
      min-height: 340px;
      display:flex;
      align-items:center;
      justify-content:center;
    }

    .halo{
      position:absolute; inset:-20%;
      background:
        radial-gradient(circle at 60% 35%, rgba(212,165,75,.16) 0 22%, transparent 55%),
        radial-gradient(circle at 40% 65%, rgba(189,111,76,.22) 0 20%, transparent 55%),
        radial-gradient(circle at 50% 50%, rgba(255,255,255,.55) 0 35%, transparent 70%);
