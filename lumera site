      font-size:22px;
      font-weight:800;
      color:#1b0f12;
    }
    .step p{margin:0; font-size:17.5px; font-weight:600;}

    .cta-block{
      background: var(--wine);
      color: var(--paper);
      border-radius: calc(var(--radius) + 6px);
      padding:26px;
      border:1px solid rgba(255,255,255,.12);
